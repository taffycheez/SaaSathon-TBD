# Option A: match production locally by pointing at the shared Render worker.
ANALYSIS_WORKER_URL=

# Option B: leave ANALYSIS_WORKER_URL blank and use `npm.cmd run dev:full`
# to run the local Python worker on http://127.0.0.1:8001 instead.

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o
NEXT_PUBLIC_APP_URL=http://localhost:3000
